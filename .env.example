# ──────────────────────────────────────────────────────────────────────────────
# FillXpert — Environment Variables
# Copy this file to .env and fill in real values
# .env is in .gitignore — NEVER commit .env
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=lorawan_db
POSTGRES_USER=lorawan_user
POSTGRES_PASSWORD=change_this_strong_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_a_long_random_string_minimum_32_chars

# ── MQTT Broker (Mosquitto on Oracle VM) ─────────────────────────────────────
MQTT_BROKER_HOST=140.245.7.35
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=fillxpert-backend-prod

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000
